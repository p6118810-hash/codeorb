NODE_ENV=development
APP_NAME=Code Orb API
PORT=3101
API_PREFIX=api
SWAGGER_ENABLED=true
CORS_ORIGINS=http://localhost:3000

# Optional Postgres connection string. If omitted, the app uses a local SQL.js file.
DATABASE_URL=
DATABASE_STORAGE=code-orb-dev.sqlite
DB_SYNC=true
JWT_SECRET=change-me-for-production
JWT_EXPIRES_IN=30d
